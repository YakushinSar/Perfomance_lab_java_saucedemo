<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite name="All Homework Tests">

    <!-- Слушатели -->
    <listeners>
        <!-- Для глобального ретрая (IRetryAnalyzer) -->
        <listener class-name="homework8.utils.AnnotationTransformer"/>
        <!-- Для логирования тестов (ITestListener) -->
        <listener class-name="homework8.utils.TestListener"/>
    </listeners>

    <test name="Homework8 Tests">
        <packages>
            <package name="homework8.tests"/>
        </packages>
    </test>

</suite>