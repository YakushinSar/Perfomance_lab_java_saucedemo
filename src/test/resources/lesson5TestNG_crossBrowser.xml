<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "http://testng.org/testng-1.0.dtd">
<suite thread-count="1"
       name="Sauce demo"
       parallel="classes">

    <test name="Хром">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="lesson5TestNG.tests.LoginTest"/>
            <class name="lesson5TestNG.tests.BaseTest"/>
            <parameter name="browser" value="chrome"></parameter>
        </classes>
    </test>

    <test name="Файрфокс">
        <classes>
            <class name="lesson5TestNG.tests.LoginTest"/>
            <parameter name="browser" value="firefox"></parameter>
        </classes>
    </test>
</suite>
